export PATH=$PATH:/home/leangeder/.go/bin
export PATH=$PATH:/home/leangeder/.cargo/bin
export EDITOR=vim
export TERM=xterm
export TERM=xterm-256color
export GPG_TTY=$(tty)
export LANG=fr_FR.UTF-8
export LC_ALL=fr_fr.UTF-8


[[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]] && . "/opt/homebrew/etc/profile.d/bash_completion.sh"

if [ -d ~/.bashrc.d ]
then
   for f in ~/.bashrc.d/*
   do
      source $f
   done
fi
