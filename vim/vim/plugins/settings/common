if isdirectory('/usr/local/opt/fzf')
  Plugin '/usr/local/opt/fzf' | Plug 'junegunn/fzf.vim'
else
  Plugin 'junegunn/fzf', { 'dir': '~/.fzf', 'do': './install --bin' }
  Plugin 'junegunn/fzf.vim'
endif
let g:make = 'gmake'
if exists('make')
        let g:make = 'make'
endif
Plugin 'Shougo/vimproc.vim', {'do': g:make}

